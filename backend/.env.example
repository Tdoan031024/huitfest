# Runtime
NODE_ENV=production
PORT=3005

# Database
DATABASE_URL=mysql://user:password@127.0.0.1:3306/huitfest

# Admin auth
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_COOKIE_SECURE=true

# CORS (comma-separated list in production)
CORS_ALLOWED_ORIGINS=https://admin.example.com,https://example.com

# Ticket token
TICKET_TOKEN_SECRET=replace-with-another-long-random-secret
TICKET_TOKEN_TTL_SECONDS=604800

# Public URLs
PUBLIC_SITE_URL=https://example.com
TICKET_PORTAL_URL=https://example.com
EMAIL_ASSET_BASE_URL=https://example.com

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=HUIT Fest <no-reply@example.com>

# Optional email assets/info
EMAIL_LOGO_URL=https://example.com/assets/images/logo/logo.webp
EMAIL_BANNER_URL=https://example.com/assets/images/banner/banner.webp
EVENT_INFO_URL=https://example.com
EVENT_SUPPORT_EMAIL=support@example.com
EVENT_SUPPORT_PHONE=0900000000
EVENT_DISPLAY_NAME=HUIT FEST 2026
EVENT_DATETIME=01-01-2026 19:00
EVENT_LOCATION=HCMC
EVENT_TICKET_INFO=Thong tin ve
