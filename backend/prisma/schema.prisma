generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model agendaitem {
  id        Int      @id @default(autoincrement())
  eventId   Int
  title     String
  startTime DateTime
  endTime   DateTime
  sortOrder Int      @default(0)
  event     event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "AgendaItem_eventId_fkey")

  @@index([eventId], map: "AgendaItem_eventId_idx")
}

model adminuser {
  id           Int       @id @default(autoincrement())
  username     String    @unique(map: "AdminUser_username_key")
  passwordHash String    @db.VarChar(255)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  lastLoginAt  DateTime?
}

model artist {
  id        Int     @id @default(autoincrement())
  eventId   Int
  name      String
  imageUrl  String?
  sortOrder Int     @default(0)
  event     event   @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "Artist_eventId_fkey")

  @@index([eventId], map: "Artist_eventId_idx")
}

model event {
  id               Int            @id @default(autoincrement())
  slug             String         @unique(map: "Event_slug_key")
  title            String
  subtitle         String?
  description      String         @db.Text
  heroImage        String?
  startAt          DateTime
  endAt            DateTime
  registrationOpen Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  pageConfig       Json?
  agendaitem       agendaitem[]
  artist           artist[]
  journeyitem      journeyitem[]
  registration     registration[]
  ruleitem         ruleitem[]
  sponsor          sponsor[]
  timelineitem     timelineitem[]
}

model journeyitem {
  id          Int      @id @default(autoincrement())
  eventId     Int
  title       String?
  description String?  @db.Text
  imageUrl    String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  event       event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "JourneyItem_eventId_fkey")

  @@index([eventId], map: "JourneyItem_eventId_idx")
  @@index([eventId, sortOrder], map: "JourneyItem_eventId_sortOrder_idx")
}

model registration {
  id        Int      @id @default(autoincrement())
  eventId   Int
  fullName  String
  email     String
  phone     String
  school    String?
  province  String?
  role      String?
  major     String?
  campus    String?
  checkedIn Boolean  @default(false)
  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime
  event     event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "Registration_eventId_fkey")

  @@index([email], map: "Registration_email_idx")
  @@index([eventId], map: "Registration_eventId_idx")
  @@index([phone], map: "Registration_phone_idx")
}

model ruleitem {
  id        Int      @id @default(autoincrement())
  eventId   Int
  title     String?
  content   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  event     event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "RuleItem_eventId_fkey")

  @@index([eventId], map: "RuleItem_eventId_idx")
  @@index([eventId, sortOrder], map: "RuleItem_eventId_sortOrder_idx")
}

model sponsor {
  id        Int      @id @default(autoincrement())
  eventId   Int
  name      String?
  imageUrl  String?  @db.Text
  linkUrl   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  event     event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "Sponsor_eventId_fkey")

  @@index([eventId], map: "Sponsor_eventId_idx")
  @@index([eventId, sortOrder], map: "Sponsor_eventId_sortOrder_idx")
}

model timelineitem {
  id          Int      @id @default(autoincrement())
  eventId     Int
  timeLabel   String?
  title       String?
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  event       event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "TimelineItem_eventId_fkey")

  @@index([eventId], map: "TimelineItem_eventId_idx")
  @@index([eventId, sortOrder], map: "TimelineItem_eventId_sortOrder_idx")
}
