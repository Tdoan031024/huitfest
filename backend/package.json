{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev && npm run prisma:apply-huitfest",
    "prisma:apply-huitfest": "node scripts/apply-huitfest-sql.js",
    "prisma:push": "prisma db push",
    "db:seed": "prisma db seed",
    "admin:create": "ts-node scripts/dev/create-admin.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "HUIT Fest dynamic landing backend (NestJS + MySQL + Prisma)",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/serve-static": "^5.0.4",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "multer": "^2.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
